---
import Layout from "../layouts/Layout.astro";
const photos = [
  "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800",
  "https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800",
  "https://images.unsplash.com/photo-1600566753086-00f18fb6b3ea?w=800",
  "https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=800",
  "https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=800",
  "https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=800",
  "https://images.unsplash.com/photo-1493809842364-78817add7ffb?w=800",
  "https://images.unsplash.com/photo-1583608205776-bfd35f0d9f83?w=800",
];
---

<Layout title="002. Scroll ImageAnimation">
  <section class="fv">
    <h1>Scroll ImageAnimation</h1>
  </section>
  <section class="section">
    <div class="track" data-scroll-track="">
      <div class="pin" data-scroll-pin="">
        <div class="list" data-scroll-list="">
          {
            photos.map((photo) => (
              <div class="item" data-scroll-item="">
                <div class="image" data-scroll-image="">
                  <img src={photo} alt="" />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  body {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  .fv {
    width: 100%;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: #000;
    color: #fff;
  }
  .section {
    overflow: clip;
  }
  .track {
    position: relative;
    width: 100%;
    height: 300vh;
  }
  .pin {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .list {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    position: relative;
  }
  .item {
    overflow: hidden;
    width: 100%;
    height: 50vh;
  }
  .image {
    width: 100%;
    height: 100%;
  }
  .image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script>
  // @ts-nocheck
  import { gsap } from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  class ScrollImageAnimation {
    constructor() {
      this.count = 8;
      this.radius = 300;
      this.selector = {
        track: document.querySelector("[data-scroll-track]"),
        pin: document.querySelector("[data-scroll-pin]"),
        items: document.querySelectorAll("[data-scroll-item]"),
        images: document.querySelectorAll("[data-scroll-image]"),
      };
      this.init();
    }

    init() {
      this._setInitialPositions();
      this._initScrollTrigger();
    }

    _setInitialPositions() {
      this.selector.images.forEach((image, index) => {
        const angle = (index / this.count) * Math.PI * 2;
        const x = Math.cos(angle) * this.radius;
        const y = Math.sin(angle) * this.radius;
        gsap.set(image, {
          position: "absolute",
          left: "50%",
          top: "50%",
          xPercent: -50,
          yPercent: -50,
          x,
          y,
          width: "300px",
          height: "300px",
        });
      });
    }

    _initScrollTrigger() {
      this.selector.items.forEach((item, index) => {
        const rect = item.getBoundingClientRect();
        console.log(index, rect.left, rect.top, rect.width, rect.height);
      });
      this.selector.images.forEach((image) => {
        gsap.to(image, {
          scrollTrigger: {
            trigger: this.selector.track,
            start: "top top",
            end: "bottom top",
            scrub: true,
          },
          x: 0,
          y: 0,
          width: image.offsetWidth,
          height: image.offsetHeight,
          ease: "none",
        });
      });
    }
  }

  new ScrollImageAnimation();
</script>
