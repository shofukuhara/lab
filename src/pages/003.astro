---
import Layout from "../layouts/Layout.astro";
---

<Layout title="003. a11y modal">
  <section class="fv">
    <h1>a11y modal</h1>
    <button class="button" data-modal-open="" aria-expanded="false"
      >Open Modal</button
    >
  </section>
  <section class="contents">
    <h2>Content</h2>
  </section>
  <dialog>
    <button class="button" data-modal-close="" aria-label="モーダルを閉じる"
      >✕</button
    >
  </dialog>
</Layout>

<style>
  body {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  .fv {
    width: 100%;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: #000;
    color: #fff;
    position: relative;
  }
  .button {
    position: fixed;
    top: 28px;
    right: 28px;
    display: inline-flex;
    align-items: center;
    padding: 10px 24px;
    font-size: 15px;
    font-weight: 500;
    color: #000;
    background: #fff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    letter-spacing: 0.02em;
    transition:
      opacity 0.15s,
      transform 0.1s;
    mix-blend-mode: difference;
  }

  .button:hover {
    opacity: 0.85;
  }

  .button:active {
    transform: scale(0.97);
  }
  .contents {
    width: 100%;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    background-color: #fff;
    color: #000;
  }
  dialog {
    background-color: #ffffff;
    width: 100%;
    height: 100vh;
    max-width: 100%;
    max-height: 100%;
  }
  dialog {
    opacity: 0;
  }
</style>

<script>
  // @ts-nocheck
  import { gsap } from "gsap";
  class DialogControl {
    constructor() {
      this.button = {
        open: document.querySelector("[data-modal-open]"),
        close: document.querySelector("[data-modal-close]"),
      };
      this.dialog = document.querySelector("dialog");
      this.init();
    }

    init() {
      this.button.open.addEventListener("click", () => {
        this._open();
      });
      this.button.close.addEventListener("click", () => {
        this._close();
      });
    }

    _open() {
      this.dialog.showModal();
      this.button.open.setAttribute("aria-expanded", "true");
      gsap.to(this.dialog, {
        opacity: 1,
        duration: 0.3,
        ease: "power2.out",
      });
    }

    _close() {
      this.button.open.setAttribute("aria-expanded", "false");
      gsap.to(this.dialog, {
        opacity: 0,
        duration: 0.3,
        ease: "power2.out",
        onComplete: () => {
          this.dialog.close();
        },
      });
    }
  }

  new DialogControl();
</script>
